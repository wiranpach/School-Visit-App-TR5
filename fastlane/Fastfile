default_platform(:ios)

platform :ios do
  desc "Build the iPadOS Client app using Ad-Hoc signing"
  lane :build_ad_hoc do
    # 1. Read environment variables passed from GitHub runner
    certificate_p12 = ENV["APP_CERTIFICATE_PATH"]
    provision_profile = ENV["PROVISION_PROFILE_PATH"]
    keychain_pwd = ENV["KEYCHAIN_PASSWORD"] || "temp_password_123"

    # Temporary keychain configuration
    keychain_name = "fastlane_tmp_keychain"

    # 2. Create a temporary keychain
    create_keychain(
      name: keychain_name,
      password: keychain_pwd,
      default_keychain: true,
      unlock: true,
      timeout: 3600,
      lock_when_sleeps: false
    )

    # 3. Import Provisioning Profile
    import_provisioning_profile(path: provision_profile)

    # 4. Import Certificate (.p12)
    import_certificate(
      keychain_name: keychain_name,
      keychain_password: keychain_pwd,
      certificate_path: certificate_p12,
      certificate_password: "",
      allow_non_existent: false
    )

    # 5. Build and archive the application package (using exact parameters requested)
    build_app(
      scheme: "EEFForm",
      export_method: "ad-hoc",
      output_directory: "./build",
      output_name: "EEF_App.ipa"
    )

    # 6. Cleanup temporary keychain after archiving completes
    delete_keychain(name: keychain_name)
  end
end
